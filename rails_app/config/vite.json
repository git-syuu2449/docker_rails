{
  "all": {
    "sourceCodeDir": "app/assets",
    "watchAdditionalPaths": [
      "app/assets",
      "vendor/assets"
    ],
    "additionalEntrypoints": [
      "~/js/**/*",
      "~/css/**/*",
      "~/images/**/*"
    ]
  },
  "development": {
    "host": "0.0.0.0",
    "autoBuild": true,
    "publicOutputDir": "vite-dev",
    "port": 3036
  },
  "test": {
    "autoBuild": true,
    "publicOutputDir": "vite-test",
    "port": 3037
  }
}
