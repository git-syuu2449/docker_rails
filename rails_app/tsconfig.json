{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["app/frontend/js/*"],
      "@css/*": ["app/frontend/css/*"],
      "@components/*": ["app/frontend/js/components/*"],
    },
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true
  },
  "include": ["app/frontend/**/*"],
  "exclude": ["node_modules"]
}